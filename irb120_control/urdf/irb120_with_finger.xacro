<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="abb_irb120_3_58">

  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="use_fake_hardware" default="false"/>
  <xacro:arg name="fake_sensor_commands" default="false"/>
  <xacro:arg name="rws_ip" default="None"/>
  <xacro:arg name="rws_port" default="80"/>
  <xacro:arg name="rws_username" default="ROS"/>
  <xacro:arg name="rws_password" default="robotics"/>
  <xacro:arg name="egm_port" default="6511"/>
  <xacro:arg name="configure_via_rws" default="true"/>

  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="use_fake_hardware" value="$(arg use_fake_hardware)"/>
  <xacro:property name="fake_sensor_commands" value="$(arg fake_sensor_commands)"/>
  <xacro:property name="rws_ip" value="$(arg rws_ip)"/>
  <xacro:property name="rws_port" value="$(arg rws_port)"/>
  <xacro:property name="rws_username" value="$(arg rws_username)"/>
  <xacro:property name="rws_password" value="$(arg rws_password)"/>
  <xacro:property name="egm_port" value="$(arg egm_port)"/>
  <xacro:property name="configure_via_rws" value="$(arg configure_via_rws)"/>

  <xacro:include filename="$(find irb120_control)/urdf/irb120_3_58_macro.xacro"/>
  <xacro:include filename="$(find irb120_control)/urdf/irb120_3_58.ros2_control.xacro"/>
  <xacro:abb_irb120_3_58 prefix="${prefix}"/>

  <xacro:abb_irb120_3_58_ros2_control
    name="ABBSystemHardware"
    prefix="${prefix}"
    use_fake_hardware="${use_fake_hardware}"
    fake_sensor_commands="${fake_sensor_commands}"
    rws_ip="${rws_ip}"
    rws_port="${rws_port}"
    rws_username="${rws_username}"
    rws_password="${rws_password}"
    egm_port="${egm_port}"
    configure_via_rws="${configure_via_rws}"/>

  <!-- ====== Params to tweak ====== -->
  <xacro:property name="ft_mass" value="0.255"/>          <!-- kg (sensor) (from spec sheet) -->
  <xacro:property name="ft_cog_z" value="0.063"/>         <!-- meters in tool frame (from spec sheet)-->
  <xacro:property name="ft_length" value="0.08225"/>         <!-- FT sensor length -->
  <xacro:property name="finger_mass" value="0.066"/>      <!-- kg (finger) (from onshape) -->
  <xacro:property name="finger_length" value="0.100"/>   <!-- finger length (from onshape)-->
  <xacro:property name="finger_mesh" value="package://irb120_control/urdf/pusher_link.stl"/>
  <!-- Total offset from link_6 to finger tip will be ft_length + finger_length -->

  <xacro:property name="table_thickness" value="0.044"/>
  <xacro:property name="bracket_thickness" value="0.021"/>
  <xacro:property name="table_center_x" value="0.40"/>
  <xacro:property name="table_center_y" value="0.0"/>

  <!-- FT sensor internal-frame mapping relative to link_6 (requested):
       x_link6 ~ z_ft, y_link6 ~ -x_ft, z_link6 ~ -y_ft (right-hand completion).
       Then we apply the inverse on ft_to_finger so finger stays in link_6/world-like
       orientation at home for task reasoning. -->
  <xacro:property name="ft_mount_roll" value="-1.5708"/>
  <xacro:property name="ft_mount_pitch" value="0.0"/>
  <xacro:property name="ft_mount_yaw" value="-1.5708"/>

  <xacro:property name="finger_unwind_roll" value="0.0"/>
  <xacro:property name="finger_unwind_pitch" value="-1.5708"/>
  <xacro:property name="finger_unwind_yaw" value="1.5708"/>

  <!-- world: base_link is at x=y=0; table top surface is z=0 -->
  <link name="world"/>

  <!-- ====== Table that the robot and object rest on (for collision and visuals) ====== -->
  <link name='table'>
    <visual>
      <origin xyz="0 0 -${table_thickness / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 0.8 ${table_thickness}"/>
      </geometry>
      <material name="Brown">
        <color rgba="0.992 0.984 0.831 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -${table_thickness / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 0.8 ${table_thickness}"/>
      </geometry>
    </collision>
  </link>

  <!-- ====== Bracket that robot sits on, ontop of the table ====== -->
  <link name='bracket'>
    <visual>
      <origin xyz="0 0 ${bracket_thickness / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="0.194 0.8 ${bracket_thickness}"/>
      </geometry>
      <material name="LightGrey">
        <color rgba="0.8 0.8 0.8 1.0"/>
      </material>
    </visual>
  </link>


  <!-- ====== FT sensor link mounted to link_6 ====== -->
  <link name="ft_link">
    <inertial>
      <origin xyz="0 0 ${ft_cog_z}" rpy="0 0 0"/>
      <mass value="${ft_mass}"/>
      <inertia ixx="5e-4" iyy="5e-4" izz="5e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 ${ft_length / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="${ft_length}"/>
      </geometry>
      <material name="LightGrey">
        <color rgba="0.8 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
        <origin xyz="0 0 ${ft_length / 2}" rpy="0 0 0"/>
        <geometry>
            <cylinder radius="0.025" length="${ft_length / 2.5}"/> <!-- collision smaller to not interfere with finger (they never collide) -->
        </geometry>
    </collision>
  </link>

  <!-- ====== Finger link ====== -->
  <link name="finger_link">
    <inertial>
        <origin xyz="0 0 0.026" rpy="0 1.5708 0"/>   <!-- adjust CoG -->
        <mass value="${finger_mass}"/>                   <!-- kg -->
        <inertia ixx="70.297" iyy="70.297" izz="70.297" ixy="0" ixz="0" iyz="0"/> <!-- kg mm^2-->
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <geometry>
          <mesh filename="${finger_mesh}"/>
        </geometry>
        <material name="White">
            <color rgba="1.0 1.0 1.0 1.0"/>
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <geometry>
            <mesh filename="${finger_mesh}"/>
        </geometry>
    </collision>
  </link>

  <!-- ==================================== JOINTS ==================================== -->

  <!-- connect link_6 to ft_link -->
  <joint name="link_6_to_ft" type="fixed">
    <parent link="link_6"/>
    <origin
      xyz="0 0 0"
      rpy="${ft_mount_roll} ${ft_mount_pitch} ${ft_mount_yaw}"/>
    <child link="ft_link"/>
  </joint>

  <!-- connect ft_link to finger_link -->
  <joint name="ft_to_finger" type="fixed">
    <parent link="ft_link"/>
    <origin
      xyz="0 0 ${ft_length}"
      rpy="${finger_unwind_roll} ${finger_unwind_pitch} ${finger_unwind_yaw}"/>
    <child link="finger_link"/>
  </joint>

  <!-- finger_ball_center at the very end of the finger for EE position (like mujoco 'site') -->
  <link name="finger_ball_center"/>
  <joint name="finger_to_tip" type="fixed">
    <parent link="finger_link"/>
    <origin xyz="${finger_length} 0 0" rpy="0 0 0"/>
    <child link="finger_ball_center"/>
  </joint>

  <joint name="world_to_table" type="fixed">
    <parent link="world"/>
    <origin xyz="${table_center_x} ${table_center_y} 0" rpy="0 0 0"/>
    <child link="table"/>
  </joint>

  <joint name="world_to_bracket" type="fixed">
    <parent link="world"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <child link="bracket"/>
  </joint>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <origin xyz="0 0 ${bracket_thickness}" rpy="0 0 0"/>
    <child link="base_link"/>
  </joint>

</robot>